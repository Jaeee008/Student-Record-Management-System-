<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500" prefWidth="700" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studentdb.controller.StudentController">

    <children>
        <Label layoutX="250" layoutY="20" text="Student Record Management" />

        <Label layoutX="50" layoutY="70" text="Name:" />
        <TextField fx:id="txtName" layoutX="150" layoutY="65" prefHeight="26.0" prefWidth="474.0" />

        <Label layoutX="50" layoutY="110" text="Course:" />
        <TextField fx:id="txtCourse" layoutX="150" layoutY="105" prefHeight="26.0" prefWidth="474.0" />

        <Label layoutX="50" layoutY="150" text="Year Level:" />
        <ChoiceBox fx:id="cbYear" layoutX="150" layoutY="145" prefHeight="26.0" prefWidth="474.0" />

        <Button layoutX="150.0" layoutY="184.0" onAction="#addStudent" prefHeight="26.0" prefWidth="210.0" text="Add" />
        <Button layoutX="150.0" layoutY="218.0" onAction="#updateStudent" prefHeight="26.0" prefWidth="210.0" text="Update" />
        <Button layoutX="413.0" layoutY="218.0" onAction="#deleteStudent" prefHeight="26.0" prefWidth="210.0" text="Delete" />
        <Button layoutX="413.0" layoutY="183.0" onAction="#clearFields" prefHeight="26.0" prefWidth="210.0" text="Clear" />

        <TableView fx:id="table" layoutX="50" layoutY="260" prefHeight="200" prefWidth="600">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80" text="ID" />
                <TableColumn fx:id="colName" prefWidth="180" text="Name" />
                <TableColumn fx:id="colCourse" prefWidth="180" text="Course" />
                <TableColumn fx:id="colYear" prefWidth="160" text="Year Level" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
